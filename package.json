{
  "name": "dawn",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "ww",
  "description": "Dawn Browser - AI-powered desktop browser",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently -k --success first \"npm run dev\" \"cross-env NODE_ENV=development electron .\"",
    "pack:win": "vite build && electron-builder --win",
    "pack:linux": "vite build && electron-builder --linux",
    "pack:mac": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "vue": "^3.5.13",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.dawn.browser",
    "productName": "Dawn",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": ["portable"],
      "signAndEditExecutable": false
    },
    "mac": {
      "icon": "public/icon.png"
    },
    "linux": {
      "icon": "public/icon.png",
      "target": ["AppImage"]
    }
  }
}
